# GitHub Actions Secrets (Settings > Secrets and variables > Actions)
# Real values go only in GitHub Secrets — never commit an actual .env with these.

# Docker Hub (build-and-push job)
DOCKERHUB_TOKEN=

# Deploy server (deploy job, SSH/SCP)
SERVER_HOST=
SERVER_USER=
SERVER_SSH_KEY=
SERVER_PORT=22

# App env — injected into containers via docker-compose.prod.yml `environment:` pass-through
SECRET_KEY=
DEBUG=false
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=db
POSTGRES_PORT=5432
BOT_TOKEN=
BOT_SERVER=
WEBHOOK_URL=
BASE_SITE=
